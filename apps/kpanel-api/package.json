{
  "name": "kpanel-api",
  "version": "0.1.0",
  "private": true,
  "description": "KPanel API - Multi-tenant website health monitoring and content management brain",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node dist/index.js",
    "build": "node --experimental-strip-types src/index.js 2>/dev/null || echo 'Use ts-node or tsx for TypeScript'",
    "test": "node --test src/**/*.test.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "express": "^4.21.0",
    "mongoose": "^8.8.0",
    "dotenv": "^16.4.5",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.4.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "eslint": "^9.15.0"
  },
  "engines": {
    "node": ">=20"
  }
}
