# KPanel API environment variables
# Copy to .env and fill in values.

NODE_ENV=development
PORT=3001

# MongoDB (local or Atlas)
MONGO_URI=mongodb://localhost:27017/kpanel

# JWT secret (use a long random string in production)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Netlify API token (optional – for deploy status / Import from Netlify)
# Create at: https://app.netlify.com/user/applications#personal-access-tokens
NETLIFY_TOKEN=

# Public base URL of this API (for webhooks, callbacks)
API_BASE_URL=http://localhost:3001

# Default platform admin – created on first startup (change in production)
ADMIN_EMAIL=admin@kpanel.local
ADMIN_PASSWORD=changeme
